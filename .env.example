# Supabase (server-side admin client uses the service role key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Express server port
PORT=3000

# RetinaPilot ML backend (FastAPI on Hugging Face Spaces).
# The server posts uploaded fundus images to ${DR_API_URL}/predict and
# normalizes the response in server/mlClient.ts. The API key is required
# for RetinaPilot's Space; the partner Space below is open.
DR_API_URL=https://faizan055-dr-classifier.hf.space
DR_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Partner model. Setting this URL surfaces a model picker on the doctor
# dashboard (RetinaPilot v1 / Partner Model). Leave unset to hide the picker.
DR_API_URL_PARTNER=https://hissanzahir-dr-detection-api.hf.space
# DR_API_KEY_PARTNER=  # (only set if the partner adds an x-api-key guard)

# Vite client envs (for client/.env, not here):
#   VITE_SUPABASE_URL=https://your-project.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ...   # publishable key, NOT the service role
